# ---- Elastic Cloud ----
# From cloud.elastic.co > your deployment > "Manage" > Cloud ID
ELASTIC_CLOUD_ID=
# From cloud.elastic.co > your deployment > Security > API Keys (create one)
ELASTIC_API_KEY=

# ---- AWS Bedrock ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Verify the exact ID in Bedrock console > Model catalog > the model > "Inference profile"
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ---- Twilio (fill in once Sandbox is configured) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
